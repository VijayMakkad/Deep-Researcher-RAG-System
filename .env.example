# Deep Researcher — Environment Configuration
# Copy this file to .env and adjust values as needed.

# ── Backend Selection ──────────────────────────────────────────────────────
# Which summariser to use by default: lexrank | distilbart | ollama
SUMMARIZER_BACKEND=lexrank

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3
OLLAMA_HOST=localhost:11434

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking ───────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ── Upload Limits ──────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Frontend ───────────────────────────────────────────────────────────────
# Used by the Streamlit app to find the backend
API_BASE_URL=http://127.0.0.1:8000
